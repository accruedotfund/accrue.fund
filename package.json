{
  "name": "accrue.fund",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Accrue — dollar accounts with Steady / Growth Boost. https://accrue.fund",
  "homepage": "https://accrue.fund",
  "repository": {
    "type": "git",
    "url": "https://github.com/accruedotfund/accrue.fund.git"
  },
  "scripts": {
    "dev": "bunx --bun vite",
    "test": "bun test",
    "build": "tsc -b && bunx --bun vite build",
    "release:check": "node scripts/validate-release.mjs",
    "build:release": "node scripts/validate-release.mjs && tsc -b && bunx --bun vite build --mode production",
    "android:release": "bun run build:release && npx cap sync android && cd android && ./gradlew bundleRelease",
    "ios:release": "bun run build:release && npx cap sync ios",
    "preview": "bunx --bun vite preview",
    "ios": "bun run build && npx cap sync ios && npx cap open ios",
    "android": "bun run build && npx cap sync android && npx cap open android"
  },
  "dependencies": {
    "@capacitor/browser": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@coinbase/cdp-sdk": "^1.53.0",
    "@privy-io/node": "^0.26.0",
    "@privy-io/react-auth": "^3.33.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@privy-io/server-auth": "^1.32.5",
    "@rollup/rollup-darwin-arm64": "^4.62.2",
    "@rollup/rollup-darwin-x64": "^4.62.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vercel/node": "^5.8.26",
    "@vitejs/plugin-react": "^4.3.1",
    "sharp": "^0.35.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  }
}
