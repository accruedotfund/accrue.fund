# ═══════════════════════════════════════════════════════════════════════════
# Accrue — https://accrue.fund
# Copy to .env.local and fill REQUIRED. Never commit .env.local.
# Never put PRIVY_APP_SECRET (or any private key) in this file.
# ═══════════════════════════════════════════════════════════════════════════

# ── REQUIRED ───────────────────────────────────────────────────────────────
# Privy → Accrue app → Settings → App ID (public, looks like cm… / cl…)
VITE_PRIVY_APP_ID=

# OPTIONAL for web. REQUIRED for Capacitor native.
# Must start with "client-" — from Privy → Clients → Mobile client.
# NEVER paste App Secret (privy_app_…) here — that breaks login and leaks secrets.
VITE_PRIVY_CLIENT_ID=

# ── RECOMMENDED ────────────────────────────────────────────────────────────
# API origin for bank cashout sessions. Empty = Relay-only withdraw (still works).
VITE_API_BASE=https://accrue.fund

# Preferred Robinhood RPC (paid key first if you have one).
# Free fallbacks are always tried after this: PublicNode → Blockscout → official.
VITE_RH_RPC=https://robinhood-rpc.publicnode.com
# VITE_RH_RPCS=https://robinhood-mainnet.g.alchemy.com/v2/YOUR_KEY,https://robinhood-rpc.publicnode.com

# ── CHAIN (defaults are Robinhood mainnet — change only if you redeploy) ───
VITE_WRAPPER_FACTORY=0xa9d906b8e0FFb15fdff5Efb50eEee34F1165bB03
VITE_BOOST_ROUTER=0x89e5db8b5aa49aa85ac63f691524311aeb649eba
VITE_USD_STABLE=0x5fc5360D0400a0Fd4f2af552ADD042D716F1d168
VITE_USD_DECIMALS=6

# wUSDG — leave empty to auto-create on first gas-sponsored login, or paste after forge:
VITE_USD_WRAPPER=

# Steady Boost LP (USDG/wUSDG). Empty = resolve on-chain when it exists.
VITE_USD_BOOST_PAIR=

# ── OPTIONAL ───────────────────────────────────────────────────────────────
# Relay (production defaults if unset)
# VITE_RELAY_QUOTE_URL=https://api.relay.link/quote/v2
# VITE_RELAY_STATUS_URL=https://api.relay.link/intents/status/v3

# Growth pool overrides (empty = deepest live USDG↔stock among curated list)
# VITE_PAIR_FACTORY=0x8bceaa40b9acdfaedf85adf4ff01f5ad6517937f
# VITE_GROWTH_PAIR_TSLA=0x30804c611286A1B19FaBDe3a4e55693aB861214A
# VITE_GROWTH_PAIR_NVDA=
# VITE_GROWTH_PAIR_AAPL=

# Future rails (tabled in UI — leave empty)
VITE_EUR_STABLE=
VITE_EUR_WRAPPER=
VITE_EUR_BOOST_PAIR=
VITE_EUR_DECIMALS=
VITE_GBP_STABLE=
VITE_GBP_WRAPPER=
VITE_GBP_BOOST_PAIR=
VITE_GBP_DECIMALS=
VITE_XAU_STABLE=
VITE_XAU_WRAPPER=
VITE_XAU_BOOST_PAIR=
VITE_XAU_DECIMALS=

# release:check which rails must be live (comma-separated)
ACTIVE_RAILS=USD

# ── NOT FOR THIS FILE (server / Vercel only — never VITE_*) ────────────────
# PRIVY_APP_SECRET=                    # optional bearer verify on offramp API
# CDP_API_KEY_ID=organizations/.../apiKeys/...   # Coinbase Developer Secret key id
# CDP_API_KEY_SECRET=-----BEGIN ...    # or Ed25519 secret; use \n for PEM newlines
# ACCRUE_OFFRAMP_REDIRECT_URL=https://accrue.fund
# ACCRUE_OFFRAMP_URL=https://…         # legacy generic partner URL (optional)
# ACCRUE_KEYSTORE_PASSWORD=            # Android signed AAB build
