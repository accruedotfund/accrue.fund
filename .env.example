# Accrue — https://accrue.fund
# Create a dedicated Privy app for Accrue (do not reuse credentials from any
# other product). App ID + mobile client ID are public; never put the app secret
# in this file or in a mobile build.
VITE_PRIVY_APP_ID=
VITE_PRIVY_CLIENT_ID=

# Optional: https://accrue.fund (or your API deploy) hosts /api/accrue-offramp-session.
# When empty, withdrawals settle client-side via Relay (USDG → Base USDC).
VITE_API_BASE=https://accrue.fund

# Relay (defaults to production).
# VITE_RELAY_QUOTE_URL=https://api.relay.link/quote/v2
# VITE_RELAY_STATUS_URL=https://api.relay.link/intents/status/v3

# Robinhood Chain RPCs (4663). Public fallbacks are hard-coded; put a paid
# endpoint first when you have one (Alchemy / dRPC).
VITE_RH_RPC=https://robinhood-rpc.publicnode.com
# VITE_RH_RPCS=https://robinhood-mainnet.g.alchemy.com/v2/YOUR_KEY,https://robinhood-rpc.publicnode.com

VITE_WRAPPER_FACTORY=0xa9d906b8e0FFb15fdff5Efb50eEee34F1165bB03
VITE_BOOST_ROUTER=0x89e5db8b5aa49aa85ac63f691524311aeb649eba
VITE_USD_STABLE=0x5fc5360D0400a0Fd4f2af552ADD042D716F1d168
VITE_USD_WRAPPER=
VITE_USD_BOOST_PAIR=
VITE_USD_DECIMALS=6

# Optional Growth pairs (USDG ↔ stock). Empty → resolve via PAIR_FACTORY.
# VITE_PAIR_FACTORY=0x8bceaa40b9acdfaedf85adf4ff01f5ad6517937f
# VITE_GROWTH_PAIR_TSLA=0x30804c611286A1B19FaBDe3a4e55693aB861214A

# Tabled until underlyings exist.
VITE_EUR_STABLE=
VITE_EUR_WRAPPER=
VITE_EUR_BOOST_PAIR=
VITE_EUR_DECIMALS=
VITE_GBP_STABLE=
VITE_GBP_WRAPPER=
VITE_GBP_BOOST_PAIR=
VITE_GBP_DECIMALS=
VITE_XAU_STABLE=
VITE_XAU_WRAPPER=
VITE_XAU_BOOST_PAIR=
VITE_XAU_DECIMALS=

ACTIVE_RAILS=USD
